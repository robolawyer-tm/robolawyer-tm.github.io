---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog — Pillars"
  description="Writing on analogical synthesis, local-first systems, semantic data, and beneficial outcome modeling."
>
  <header class="hero">
    <h1>Blog</h1>
    <p class="tagline">
      Writing on analogical synthesis, local-first systems, semantic data engines,
      and the pursuit of beneficial outcome modeling.
    </p>
  </header>

  <main>
    <section>
      <h2>All Posts</h2>

      {posts.length === 0 ? (
        <div class="pillar-card">
          <h3>No posts yet</h3>
          <p>Check back soon — writing in progress.</p>
        </div>
      ) : (
        posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))
      )}
    </section>
  </main>
</BaseLayout>
