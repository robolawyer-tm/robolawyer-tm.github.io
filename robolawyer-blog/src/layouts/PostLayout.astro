---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Pillars`} description={description} ogType="article">
  <header class="hero">
    <h1>{title}</h1>
    <p class="tagline">{description}</p>
    <p class="post-meta">
      <span class="post-date">{formattedDate}</span>
      {tags.length > 0 && (
        <span class="post-tags">
          {tags.map((tag) => (
            <span class="badge badge-planned">{tag}</span>
          ))}
        </span>
      )}
    </p>
  </header>

  <main class="post-body">
    <slot />
    <hr />
    <p class="back-link"><a href="/blog">← All posts</a></p>
  </main>
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
    font-style: normal;
  }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--text-subtle);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-body {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  /* Prose spacing for markdown output */
  .post-body :global(h2) { margin-top: 2.5rem; }
  .post-body :global(h3) { margin-top: 2rem; }
  .post-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .back-link {
    margin-top: 2rem;
  }
  .back-link a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--text-subtle);
  }
  .back-link a:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
